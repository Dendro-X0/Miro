{
  "name": "miro",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "turbo dev --filter=@miro/api --filter=miro-web",
    "build": "turbo build --filter=@miro/api --filter=miro-web",
    "start": "turbo start --filter=@miro/api --filter=miro-web",
    "typecheck": "turbo run typecheck --filter=@miro/api --filter=miro-web --filter=miro-mobile",
    "lint": "turbo run lint --filter=@miro/api --filter=miro-web",
    "clean": "turbo run clean",
    "desktop:dev": "pnpm --filter miro-desktop dev",
    "desktop:build": "pnpm --filter miro-desktop build",
    "desktop:release": "pnpm desktop:icon && pnpm --filter miro-desktop build:sidecar && pnpm desktop:build",
    "desktop:icon": "pnpm --filter miro-desktop icon"
  },
  "pnpm": {
    "overrides": {
      "@ai-sdk/gateway": "3.0.153"
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  }
}

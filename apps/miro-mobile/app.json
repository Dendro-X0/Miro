{
  "expo": {
    "name": "Miro",
    "slug": "miro-mobile",
    "version": "0.1.0",
    "scheme": "miro",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "jsEngine": "hermes",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

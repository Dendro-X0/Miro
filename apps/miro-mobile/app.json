{
  "expo": {
    "name": "Miro",
    "slug": "miro-mobile",
    "version": "0.2.0",
    "scheme": "miro",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "jsEngine": "hermes",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Miro to attach images for vision chat."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

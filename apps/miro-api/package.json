{
  "name": "@miro/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "src/run.ts",
  "scripts": {
    "dev": "tsx src/run.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/run.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ai-config": "tsx test/ai-config.test.ts",
    "test:ai-helpers": "tsx test/ai-helpers.test.ts",
    "test:ai-stream": "tsx --test test/ai-stream.test.ts",
    "test:ai-v2": "tsx test/ai-v2.test.ts",
    "test": "pnpm -s test:ai-config && pnpm -s test:ai-helpers && pnpm -s test:ai-stream && pnpm -s test:ai-v2"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.98",
    "@hono/node-server": "^1.19.7",
    "@miro/ai": "workspace:*",
    "@miro/auth": "workspace:*",
    "@miro/db": "workspace:*",
    "ai": "^6.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31"
  }
}

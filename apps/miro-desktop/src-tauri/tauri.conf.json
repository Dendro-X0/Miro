{
  "identifier": "com.miro.desktop",
  "productName": "Miro Desktop",
  "version": "0.2.0",
  "build": {
    "beforeDevCommand": "pnpm --filter miro-web dev",
    "devUrl": "http://localhost:3100",
    "beforeBuildCommand": "node ./scripts/build-api-sidecar.mjs && pnpm --filter miro-web build:desktop",
    "frontendDist": "../miro-web/out"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; img-src 'self' data: blob: https:; media-src 'self' blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:",
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "Miro",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#020617"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "category": "Productivity",
    "resources": [
      "resources/miro-api/*"
    ],
    "shortDescription": "Private local-first BYOK AI studio",
    "longDescription": "Miro Desktop is a private, local-first AI chat client. Bring your own API keys or connect to Ollama. Chats stay in an encrypted vault; keys stay in the OS keychain."
  }
}
